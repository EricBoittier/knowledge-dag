  <library>
    <event name="VideoPipeline">
      <project name="AutoTimeline">
        <sequence format="rFormat" tcStart="0s" tcFormat="NDF">
          <spine>
            <asset-clip name="Philosophy b-roll 1" ref="r1" offset="0/24000s" start="0/24000s" duration="144000/24000s">
              <marker start="0/24000s" duration="144000/24000s" value="Mara: Today I want to pin down a word everyone throws around after reading half a blog post: simulacrum." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 2" ref="r2" offset="144000/24000s" start="0/24000s" duration="109440/24000s">
              <marker start="0/24000s" duration="109440/24000s" value="Mara: What is it, actually, and why should anyone who edits video care?" />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 3" ref="r3" offset="253440/24000s" start="0/24000s" duration="23040/24000s">
              <marker start="0/24000s" duration="23040/24000s" value="Elias: Start smaller." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 4" ref="r4" offset="276480/24000s" start="0/24000s" duration="115200/24000s">
              <marker start="0/24000s" duration="115200/24000s" value="Elias: Alfred Korzybski's line that the map is not the territory." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 5" ref="r5" offset="391680/24000s" start="0/24000s" duration="126720/24000s">
              <marker start="0/24000s" duration="126720/24000s" value="Elias: A map is useful because it lies in a disciplined way." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 6" ref="r6" offset="518400/24000s" start="0/24000s" duration="184320/24000s">
              <marker start="0/24000s" duration="184320/24000s" value="Elias: A simulacrum begins when the map stops pointing at the territory and starts pointing only at other maps." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 7" ref="r7" offset="702720/24000s" start="0/24000s" duration="34560/24000s">
              <marker start="0/24000s" duration="34560/24000s" value="Mara: So it's not simply a fake." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 8" ref="r8" offset="737280/24000s" start="0/24000s" duration="69120/24000s">
              <marker start="0/24000s" duration="69120/24000s" value="Mara: A prop knife on stage is fake but honest." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 9" ref="r9" offset="806400/24000s" start="0/24000s" duration="38400/24000s">
              <marker start="0/24000s" duration="38400/24000s" value="Mara: The audience knows the contract." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 10" ref="r10" offset="844800/24000s" start="0/24000s" duration="9600/24000s">
              <marker start="0/24000s" duration="9600/24000s" value="Elias: Right." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 11" ref="r11" offset="854400/24000s" start="0/24000s" duration="57600/24000s">
              <marker start="0/24000s" duration="57600/24000s" value="Elias: Baudrillard sketches orders of simulacra." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 12" ref="r12" offset="912000/24000s" start="0/24000s" duration="80640/24000s">
              <marker start="0/24000s" duration="80640/24000s" value="Elias: Roughly: the image reflects a profound reality." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 13" ref="r13" offset="992640/24000s" start="0/24000s" duration="113280/24000s">
              <marker start="0/24000s" duration="113280/24000s" value="Elias: Then it masks and denatures that reality." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 14" ref="r14" offset="1105920/24000s" start="0/24000s" duration="57600/24000s">
              <marker start="0/24000s" duration="57600/24000s" value="Elias: Then it masks the absence of reality." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 15" ref="r15" offset="1163520/24000s" start="0/24000s" duration="184320/24000s">
              <marker start="0/24000s" duration="184320/24000s" value="Elias: Finally it bears no relation to any reality whatever: it is its own pure simulacrum." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 16" ref="r16" offset="1347840/24000s" start="0/24000s" duration="101760/24000s">
              <marker start="0/24000s" duration="101760/24000s" value="Mara: The fourth order sounds like nihilism with a French accent." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 17" ref="r17" offset="1449600/24000s" start="0/24000s" duration="96000/24000s">
              <marker start="0/24000s" duration="96000/24000s" value="Mara: Give me something concrete before I roll my eyes." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 18" ref="r18" offset="1545600/24000s" start="0/24000s" duration="21120/24000s">
              <marker start="0/24000s" duration="21120/24000s" value="Elias: Take your timeline." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 19" ref="r19" offset="1566720/24000s" start="0/24000s" duration="184320/24000s">
              <marker start="0/24000s" duration="184320/24000s" value="Elias: You color-grade, you stabilize, you drop in stylized B-roll until Antarctica looks like a storyboard for a feeling you already sold in the thumbnail." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 20" ref="r20" offset="1751040/24000s" start="0/24000s" duration="69120/24000s">
              <marker start="0/24000s" duration="69120/24000s" value="Elias: The clip is no longer evidence of cold air on feathers." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 21" ref="r21" offset="1820160/24000s" start="0/24000s" duration="157440/24000s">
              <marker start="0/24000s" duration="157440/24000s" value="Elias: It is evidence of the look of clips about cold air on feathers." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 22" ref="r22" offset="1977600/24000s" start="0/24000s" duration="65280/24000s">
              <marker start="0/24000s" duration="65280/24000s" value="Mara: That is uncomfortably close to my last export." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 23" ref="r23" offset="2042880/24000s" start="0/24000s" duration="69120/24000s">
              <marker start="0/24000s" duration="69120/24000s" value="Mara: Are you saying every documentary gesture is bad faith?" />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 24" ref="r24" offset="2112000/24000s" start="0/24000s" duration="5760/24000s">
              <marker start="0/24000s" duration="5760/24000s" value="Elias: No." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 25" ref="r25" offset="2117760/24000s" start="0/24000s" duration="61440/24000s">
              <marker start="0/24000s" duration="61440/24000s" value="Elias: I am saying the ethical question moves." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 26" ref="r26" offset="2179200/24000s" start="0/24000s" duration="122880/24000s">
              <marker start="0/24000s" duration="122880/24000s" value="Elias: Good faith asks what the cut still owes the world when the world has already been replaced by its previews." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 27" ref="r27" offset="2302080/24000s" start="0/24000s" duration="74880/24000s">
              <marker start="0/24000s" duration="74880/24000s" value="Mara: Hyperreality was the other buzzword in my notes." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 28" ref="r28" offset="2376960/24000s" start="0/24000s" duration="51840/24000s">
              <marker start="0/24000s" duration="51840/24000s" value="Mara: Is that just VR goggles, or something worse?" />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 29" ref="r29" offset="2428800/24000s" start="0/24000s" duration="184320/24000s">
              <marker start="0/24000s" duration="184320/24000s" value="Elias: Worse in a boring way: a model of the world that is more legible, more coherent, and more emotionally convenient than the world, so the model becomes the primary experience people defend when facts arrive inconveniently." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 30" ref="r30" offset="2613120/24000s" start="0/24000s" duration="65280/24000s">
              <marker start="0/24000s" duration="65280/24000s" value="Mara: So the simulacrum is not the lie on top of reality." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 31" ref="r31" offset="2678400/24000s" start="0/24000s" duration="69120/24000s">
              <marker start="0/24000s" duration="69120/24000s" value="Mara: It is the machinery that makes reality optional." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 32" ref="r32" offset="2747520/24000s" start="0/24000s" duration="42240/24000s">
              <marker start="0/24000s" duration="42240/24000s" value="Elias: Optional is too strong." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 33" ref="r33" offset="2789760/24000s" start="0/24000s" duration="28800/24000s">
              <marker start="0/24000s" duration="28800/24000s" value="Elias: Fragile is better." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 34" ref="r34" offset="2818560/24000s" start="0/24000s" duration="40320/24000s">
              <marker start="0/24000s" duration="40320/24000s" value="Elias: The territory still has weather." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 35" ref="r35" offset="2858880/24000s" start="0/24000s" duration="130560/24000s">
              <marker start="0/24000s" duration="130560/24000s" value="Elias: The map just trains you to argue about the icon in the corner instead of opening the door." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 36" ref="r36" offset="2989440/24000s" start="0/24000s" duration="103680/24000s">
              <marker start="0/24000s" duration="103680/24000s" value="Mara: If I keep one discipline from this conversation when I cut the next piece, what should it be?" />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 37" ref="r37" offset="3093120/24000s" start="0/24000s" duration="46080/24000s">
              <marker start="0/24000s" duration="46080/24000s" value="Elias: Name the layer where truth-claims live." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 38" ref="r38" offset="3139200/24000s" start="0/24000s" duration="178560/24000s">
              <marker start="0/24000s" duration="178560/24000s" value="Elias: When you stylize, caption, score, and compress, say out loud what each layer is allowed to prove." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 39" ref="r39" offset="3317760/24000s" start="0/24000s" duration="84480/24000s">
              <marker start="0/24000s" duration="84480/24000s" value="Elias: Simulacra win by making that question feel pretentious." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 40" ref="r40" offset="3402240/24000s" start="0/24000s" duration="13440/24000s">
              <marker start="0/24000s" duration="13440/24000s" value="Elias: It isn't." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 41" ref="r41" offset="3415680/24000s" start="0/24000s" duration="134400/24000s">
              <marker start="0/24000s" duration="134400/24000s" value="Mara: Next episode I want signs without signifiers, or maybe the opposite." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 42" ref="r42" offset="3550080/24000s" start="0/24000s" duration="78720/24000s">
              <marker start="0/24000s" duration="78720/24000s" value="Mara: For now: thanks for letting the map argue back." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 43" ref="r43" offset="3628800/24000s" start="0/24000s" duration="101760/24000s">
              <marker start="0/24000s" duration="101760/24000s" value="Elias: The map always argued back." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 44" ref="r44" offset="3730560/24000s" start="0/24000s" duration="30720/24000s">
              <marker start="0/24000s" duration="30720/24000s" value="Elias: We just turned up its gain." />
            </asset-clip>
            <asset-clip name="Philosophy b-roll 45" ref="r45" offset="3761280/24000s" start="0/24000s" duration="55680/24000s">
              <marker start="0/24000s" duration="55680/24000s" value="Elias: Try not to mistake loudness for ground truth." />
            </asset-clip>
