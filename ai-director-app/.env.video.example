# Copy to .env.video and edit values.

# Project output/work dir
PROJECT_DIR=./projects/walrus-dfs

# Optional concept text; when set, bootstraps dag.project.json
# Use \n or semicolons to separate points.
CONCEPT=

# Set 1 to overwrite existing dag.project.json when CONCEPT is set.
FORCE_REBUILD_DAG=0
DEFAULT_SEGMENT_DURATION_SEC=14

# Stage range (source -> render gives eventual video + narration pipeline)
FROM_STAGE=source
TO_STAGE=render

# Resolve pipeline variant
VARIANT=default

# Runtime flags
DRY_RUN=0
SKIP_UPLOAD=1

# Cheap voices default (espeak)
CHEAP_VOICES=1
